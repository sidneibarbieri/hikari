# =============================================================================
# Hikari Platform — Variáveis de Produção
# Copie este arquivo para .env.production e preencha TODOS os campos obrigatórios
# antes de iniciar o servidor.
# NUNCA commite o .env.production no Git.
# =============================================================================

# ---- Domínio (sem https://) -------------------------------------------------
HIKARI_DOMAIN=hikari.sua-instituicao.br

# ---- Admin ------------------------------------------------------------------
ADMIN_EMAIL=admin@sua-instituicao.br
ADMIN_PASSWORD=TrocaAntesDeImplantar!

# ---- Segredos Flask/CTFd (gere com: python3 -c "import secrets; print(secrets.token_hex(32))") ---
SECRET_KEY=
DATABASE_PASSWORD=hikari_db_pw_troque_aqui

# ---- Kibana / Elasticsearch -------------------------------------------------
# Exatamente 32 caracteres cada
KIBANA_ENCRYPTION_KEY=00112233445566778899aabbccddeeff
ES_ENCRYPTION_KEY=ffeeddccbbaa99887766554433221100

# ---- Google OAuth (opcional — deixe em branco para desativar) ---------------
# Instruções: console.cloud.google.com → APIs e Serviços → Credenciais
# → Criar credencial → ID do cliente OAuth 2.0 → Aplicativo da Web
# URI de redirecionamento: https://HIKARI_DOMAIN/hikari/auth/google/callback
HIKARI_GOOGLE_CLIENT_ID=
HIKARI_GOOGLE_CLIENT_SECRET=
# Preenchido automaticamente pelo setup_production.sh com base em HIKARI_DOMAIN
# HIKARI_OAUTH_REDIRECT_BASE=

# ---- E-mail (opcional — sem configuração envia localmente para o MailCatcher) --
# MAIL_SERVER=smtp.sua-instituicao.br
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USERNAME=hikari@sua-instituicao.br
# MAIL_PASSWORD=
# MAIL_DEFAULT_SENDER=hikari@sua-instituicao.br

# ---- Portas internas (raramente precisam ser alteradas) ---------------------
CTFD_INTERNAL_PORT=8000
ELASTIC_PORT=9200
KIBANA_INTERNAL_PORT=5601
